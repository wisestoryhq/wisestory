generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ──────────────────────────────────────────────────────────

enum WorkspaceMemberRole {
  owner
  admin
  member
}

enum MediaType {
  instagram_post
  instagram_carousel
  instagram_reel
  tiktok_video
  youtube_shorts
  youtube_video
  x_post
  x_thread
  linkedin_post
  linkedin_carousel
  multi_platform_campaign
}

enum WorkspaceCategory {
  news
  fashion
  cooking
  gaming
  tech
  health
  education
  travel
  entertainment
  other
}

enum SourceConnectionStatus {
  connected
  syncing
  error
  disconnected
}

enum SourceFileStatus {
  pending
  processing
  indexed
  error
}

enum CampaignStatus {
  draft
  briefing
  generating_doc
  completed
  failed
}

enum SourceFileContentType {
  document
  logo
  photo
  pdf
  other
}

// ─── User ───────────────────────────────────────────────────────────

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions         Session[]
  accounts         Account[]
  workspaceMembers WorkspaceMember[]

  @@map("users")
}

// ─── Better Auth: Session ───────────────────────────────────────────

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

// ─── Better Auth: Account ───────────────────────────────────────────

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("accounts")
}

// ─── Better Auth: Verification ──────────────────────────────────────

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verifications")
}

// ─── Workspace (tenant boundary) ────────────────────────────────────

model Workspace {
  id          String            @id @default(cuid())
  name        String
  slug        String            @unique
  description String?
  logo        String?
  category    WorkspaceCategory @default(other)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  members           WorkspaceMember[]
  sourceConnections SourceConnection[]
  sourceFiles       SourceFile[]
  knowledgeChunks   KnowledgeChunk[]
  campaigns         Campaign[]

  @@map("workspaces")
}

// ─── Workspace Member ───────────────────────────────────────────────

model WorkspaceMember {
  id          String              @id @default(cuid())
  role        WorkspaceMemberRole @default(member)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([workspaceId])
  @@map("workspace_members")
}

// ─── Source Connection (Google Drive) ───────────────────────────────

model SourceConnection {
  id             String                 @id @default(cuid())
  provider       String                 @default("google_drive")
  status         SourceConnectionStatus @default(connected)
  accessToken    String?
  refreshToken   String?
  tokenExpiresAt DateTime?
  folderIds      String[]
  folderNames    String[]
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  sourceFiles SourceFile[]

  @@index([workspaceId])
  @@map("source_connections")
}

// ─── Source File ────────────────────────────────────────────────────

model SourceFile {
  id           String           @id @default(cuid())
  externalId   String
  name         String
  mimeType     String
  driveUrl     String?
  size         Int?
  status       SourceFileStatus @default(pending)
  contentType   SourceFileContentType @default(other)
  imageData     String?
  extractedText String?
  errorMessage String?
  indexedAt     DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  workspaceId        String
  workspace          Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  sourceConnectionId String
  sourceConnection   SourceConnection @relation(fields: [sourceConnectionId], references: [id], onDelete: Cascade)

  knowledgeChunks KnowledgeChunk[]

  @@unique([workspaceId, externalId])
  @@index([workspaceId])
  @@index([sourceConnectionId])
  @@map("source_files")
}

// ─── Knowledge Chunk ────────────────────────────────────────────────

model KnowledgeChunk {
  id        String   @id @default(cuid())
  content   String
  embedding Float[]
  metadata  Json?
  chunkIndex Int
  createdAt DateTime @default(now())

  workspaceId  String
  workspace    Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  sourceFileId String
  sourceFile   SourceFile @relation(fields: [sourceFileId], references: [id], onDelete: Cascade)

  generationSourceRefs GenerationSourceRef[]

  @@index([workspaceId])
  @@index([sourceFileId])
  @@map("knowledge_chunks")
}

// ─── Campaign ───────────────────────────────────────────────────────

model Campaign {
  id              String         @id @default(cuid())
  mediaType       MediaType
  prompt          String
  instructions    String?
  briefingSummary String?
  status          CampaignStatus @default(draft)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  outputs              CampaignOutput[]
  messages             CampaignMessage[]
  generationSourceRefs GenerationSourceRef[]
  briefingNodes        BriefingNode[]

  @@index([workspaceId])
  @@map("campaigns")
}

// ─── Campaign Message ────────────────────────────────────────────────

model CampaignMessage {
  id        String   @id @default(cuid())
  role      String   // "user" | "assistant"
  content   String
  images    Json?    // [{data: string, mimeType: string}]
  metadata  Json?    // thinking steps, sources, etc.
  createdAt DateTime @default(now())

  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@map("campaign_messages")
}

// ─── Campaign Output ────────────────────────────────────────────────

model CampaignOutput {
  id        String   @id @default(cuid())
  version   Int      @default(1)
  parts     Json
  createdAt DateTime @default(now())

  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@map("campaign_outputs")
}

// ─── Generation Source Reference ────────────────────────────────────

model GenerationSourceRef {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  campaignId      String
  campaign        Campaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  knowledgeChunkId String
  knowledgeChunk   KnowledgeChunk @relation(fields: [knowledgeChunkId], references: [id], onDelete: Cascade)

  @@unique([campaignId, knowledgeChunkId])
  @@index([campaignId])
  @@map("generation_source_refs")
}

// ─── Briefing Node (Knowledge Graph) ─────────────────────────────

model BriefingNode {
  id            String   @id @default(cuid())
  nodeType      String   // "decision", "concept", "visual_direction", "copy_direction", "liked_image", "brand_element", "rejected_option"
  title         String
  content       String
  imageData     String?  // base64
  imageMimeType String?
  metadata      Json?
  createdAt     DateTime @default(now())

  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  outgoingEdges BriefingEdge[] @relation("source")
  incomingEdges BriefingEdge[] @relation("target")

  @@index([campaignId])
  @@map("briefing_nodes")
}

// ─── Briefing Edge (Knowledge Graph) ─────────────────────────────

model BriefingEdge {
  id               String       @id @default(cuid())
  relationshipType String       // "leads_to", "refines", "replaces", "supports", "rejected_for"
  weight           Float        @default(1.0)

  sourceId String
  source   BriefingNode @relation("source", fields: [sourceId], references: [id], onDelete: Cascade)
  targetId String
  target   BriefingNode @relation("target", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([sourceId, targetId])
  @@map("briefing_edges")
}
